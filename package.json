{
  "name": "verity-angular-teste",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "serve:ssr:verity-angular-teste": "node dist/verity-angular-teste/server/server.mjs"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.html": "eslint --fix"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.28",
    "@tailwindcss/vite": "^4.3.1",
    "express": "^5.1.0",
    "jspdf": "^4.2.1",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.28",
    "@angular/cli": "^20.3.28",
    "@angular/compiler-cli": "^20.3.0",
    "@angular/platform-browser-dynamic": "^20.3.25",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.19",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^16.2.0",
    "lint-staged": "^17.0.7",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.61.0"
  }
}
